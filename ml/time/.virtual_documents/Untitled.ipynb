import pandas as pd


df = pd.read_csv("timeline.csv")


df.head()


df.info()


from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from sklearn.multioutput import MultiOutputRegressor
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error, r2_score
import joblib
import numpy as np


encoders = {}
for col in ["material", "location", "complexity"]:
    le = LabelEncoder()
    df[col] = le.fit_transform(df[col])
    encoders[col] = le


X = df[[
    "area", "floors", "material", "location", "complexity",
    "complexity_factor", "material_factor", "location_delay"
]]


y = df[[
    "total_duration_months",
    "phase_planning_%",
    "phase_foundation_%",
    "phase_structure_%",
    "phase_finishing_%"
]]


X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)


rf = RandomForestRegressor(
    n_estimators=200,
    max_depth=12,
    min_samples_split=5,
    random_state=42,
    n_jobs=-1
)


model = MultiOutputRegressor(rf)


model.fit(X_train, y_train)


preds = model.predict(X_test)


print("MAE:", mean_absolute_error(y_test, preds))
print("R2:", r2_score(y_test, preds))


import seaborn as sns
sns.scatterplot(x=df["area"], y=df["total_duration_months"])


oblib.dump(model, "timeline_model.pkl")
joblib.dump(encoders, "timeline_encoders.pkl")



