import pandas as pd
import numpy as np
import joblib
import json
from datetime import datetime
from xgboost import XGBClassifier
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, classification_report


df = pd.read_csv("data.csv")


risk_score = (
    df["weather_index"] * 0.3 +
    df["project_complexity"] * 0.3 +
    df["labor_cost"] * 0.00005 +
    df["transport_cost"] * 0.00003
)


risk_score += np.random.normal(0, 0.5, len(df))


df["risk_label"] = pd.cut(
    risk_score,
    bins=[-np.inf, 2.5, 4.5, np.inf],
    labels=[0, 1, 2]
)


df = df.drop(columns=["Unnamed: 0", "risk_index"], errors="ignore")


from sklearn.utils import resample
df_major = df[df.risk_label == 2]
df_mid = df[df.risk_label == 1]
df_minor = df[df.risk_label == 0]

df_minor_upsampled = resample(df_minor, replace=True, n_samples=len(df_mid))

df_balanced = pd.concat([df_major, df_mid, df_minor_upsampled])


df["weather_index"] += np.random.normal(0, 0.2, len(df))


X = df.drop(["cost", "time", "risk_label"], axis=1)


y = df["risk_label"]


X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)


model = XGBClassifier(
    n_estimators=200,
    max_depth=5,
    learning_rate=0.1,
    objective="multi:softprob",
    num_class=3
)


model.fit(X_train, y_train)


preds = model.predict(X_test)


acc = accuracy_score(y_test, preds)


acc


classification_report(y_test, preds)


model_path = "risk_model_v1.pkl"


joblib.dump(model, model_path)


metadata = {
    "model_name": "risk_model_v1",
    "model": "XGBoost Classifier",
    "target": "risk_label",
    "accuracy": float(acc),
    "classes": ["Low", "Medium", "High"],
    "features": list(X.columns),
    "n_samples": len(X),
    "params": model.get_params(),
    "date": str(datetime.now())
}


with open("risk_model_v1_meta.json", "w") as f:
    json.dump(metadata, f, indent=4)



